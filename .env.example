# Copy this file to ".env" and paste your real keys after the "=" signs.
# The .env file is listed in .gitignore and must NEVER be committed.

# OpenSanctions API key — register (free, non-commercial) at:
#   https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=

# aisstream.io API key (used later in M3 for live AIS) — get it at:
#   https://aisstream.io/
AISSTREAM_API_KEY=
